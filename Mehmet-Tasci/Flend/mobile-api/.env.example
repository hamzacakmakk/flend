# Flend Mobil Backend ortam değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.

# Sunucu portu (web API 5000 kullandığı için mobil backend 5001)
PORT=5001

# Supabase bağlantısı (web API ile aynı proje/tablolar kullanılır)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...

# Mobil istemcinin Authorization: Bearer <token> başlığında göndereceği token.
# Boş bırakılırsa kimlik doğrulama devre dışı kalır (sadece geliştirme için).
MOBILE_API_TOKEN=flend-mobile-dev-token

NODE_ENV=development

# ---- Mesaj Kuyruğu ----
# Hangi broker? bullmq (Redis) | rabbitmq | kafka
QUEUE_DRIVER=bullmq
SYNC_QUEUE_NAME=product-sync
# true: worker API ile aynı process'te (tek terminal demo) | false: ayrı "npm run worker"
INLINE_WORKER=true

REDIS_URL=redis://127.0.0.1:6379
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_GROUP_ID=flend-sync-workers
