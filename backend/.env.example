# ── Flend Backend ortam değişkenleri (kopyala → .env) ────────────────────
# Yerel (npm start) için localhost; Docker `api` servisi için compose env kullanılır.

PORT=5000

# PostgreSQL (zorunlu)
DATABASE_URL=postgres://flend:flend@localhost:5432/flend

# JWT
JWT_SECRET=flend-dev-secret-change-me
JWT_EXPIRES=7d
DEMO_USER_ID=a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11

# Redis (opsiyonel — yoksa cache devre dışı)
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=60

# RabbitMQ (opsiyonel — yoksa senkron sync)
RABBITMQ_URL=amqp://localhost
RABBITMQ_SYNC_QUEUE=sync_jobs

# Kafka (opsiyonel — yoksa event publish atlanır)
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=flend-worker
KAFKA_PRICE_TOPIC=price_updated
